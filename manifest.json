{
  "manifest_version": 3,
  "name": "HDRezka Plugin",
  "version": "3.1",
  "description": "Enhances Rezka-like sites with keyboard shortcuts for playback and navigation.",
  "icons": {
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "options.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["favorites.js", "playback.js", "ui.js", "content.js"]
    }
  ],
  "options_page": "options.html"
}
